# Dynexis LaunchOps Environment Variables
# Copy this to .env and fill in your values.
# The install.sh script auto-generates secure passwords if .env doesn't exist.

# ── API Security ──────────────────────────────────────────────────────────
# Comma-separated API keys. If unset, one is auto-generated on boot.
# LAUNCHOPS_API_KEYS=lops_your_key_here
# Set to "true" ONLY for local dev (disables auth entirely):
# LAUNCHOPS_DEV_MODE=false
# Allowed CORS origin(s) for the dashboard (comma-separated):
DASHBOARD_ORIGIN=http://localhost:5173

# ── Standard LLM Routing ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override default models
# OPENAI_MODEL=gpt-4.1-mini
# DEFAULT_LLM_MODEL=claude-3-5-sonnet-latest

# ── Phase 2: ProofGuard Governance Layer ───────────────────────────────────
# Points at the Next.js/Supabase control plane from
#   https://github.com/MicroAIStudios-DAO/proofguard-ai
PROOFGUARD_API_URL=http://localhost:3000/api/attest
PROOFGUARD_API_KEY=pg_live_...
# Force every stage through HITL regardless of CQS score
ENABLE_HUMAN_APPROVAL=true
# Dev-only escape hatch — NEVER set to true in production
# PROOFGUARD_FAIL_OPEN=false
# PROOFGUARD_HITL_TIMEOUT=3600
# PROOFGUARD_POLL_INTERVAL=5

# ── Phase 2: Stripe Integration ────────────────────────────────────────────
# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Phase 2: MCP Agent-to-Agent ────────────────────────────────────────────
# Token used when this system negotiates with an EXTERNAL MCP server
# (e.g., a Bank Agent or Vendor Agent's /mcp/discover endpoint)
EXTERNAL_MCP_TOKEN=

# ── Infrastructure ─────────────────────────────────────────────────────────
# Database credentials (auto-generated by install.sh)
DB_PASSWORD=change_me_to_a_secure_password
DB_ROOT_PASSWORD=change_me_to_a_secure_root_password

# Vaultwarden admin token (auto-generated by install.sh)
VAULT_ADMIN_TOKEN=change_me_to_a_secure_token

# Domain (for production deployment with SSL)
DOMAIN=yourdomain.com

# Email SMTP (for Mautic)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
