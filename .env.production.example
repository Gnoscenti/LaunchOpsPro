# ==========================================
# FOUNDER AUTOPILOT - PRODUCTION ENVIRONMENT
# ==========================================
# Copy this file to .env.production and fill in the actual values.
# DO NOT commit .env.production to version control.

# ------------------------------------------
# 1. Application Settings
# ------------------------------------------
# Disable mock mode to use real API keys and perform actual deployments
MOCK_MODE=false
# Disable debug mode in production for security and performance
DEBUG=false
# The environment name (e.g., production, staging)
ENVIRONMENT=production
# A strong, randomly generated secret key for encrypting sessions/tokens
# Generate one using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here

# ------------------------------------------
# 2. Database Configuration
# ------------------------------------------
# The connection string for your production PostgreSQL database
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
# Example (Supabase): postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------
# 3. LLM Provider (OpenAI / vLLM)
# ------------------------------------------
# If using official OpenAI:
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# If using a self-hosted vLLM instance (e.g., on RunPod/Lambda):
# OPENAI_API_KEY=your_custom_auth_token_if_any
# OPENAI_API_BASE=https://your-vllm-instance.com/v1
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct

# ------------------------------------------
# 4. Third-Party Integrations (Agents)
# ------------------------------------------

# --- Stripe (Billing & Payments) ---
# Production API key (starts with sk_live_)
STRIPE_API_KEY=sk_live_your_stripe_api_key
# Webhook secret for verifying Stripe events
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# --- Google Cloud (Infrastructure & Secrets) ---
# The ID of your GCP project
GCLOUD_PROJECT_ID=your-gcp-project-id
# Path to the service account JSON key file (must be mounted in the container)
# Alternatively, use Workload Identity if hosting on GCP
GCLOUD_CREDENTIALS_PATH=/app/secrets/gcp-service-account.json

# --- GitHub (Repository Management) ---
# Fine-grained Personal Access Token (PAT) with repo creation permissions
GITHUB_TOKEN=github_pat_your_token_here

# --- Vercel (Frontend Deployment) ---
# Vercel API token for programmatic deployments
VERCEL_API_TOKEN=your_vercel_api_token
# Your Vercel Team ID (if deploying under a team)
VERCEL_TEAM_ID=your_vercel_team_id

# ------------------------------------------
# 5. Email Configuration (Transactional)
# ------------------------------------------
# Provider choice: smtp, sendgrid, postmark, resend
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
# The default "From" address for system emails
DEFAULT_FROM_EMAIL=noreply@founder-autopilot.com

# ------------------------------------------
# 6. Frontend Configuration (Vite)
# ------------------------------------------
# The public URL of your deployed FastAPI backend
# This is used by the React frontend to make API calls
VITE_API_URL=https://api.founder-autopilot.com

# ------------------------------------------
# 7. Security & CORS
# ------------------------------------------
# Comma-separated list of allowed origins for CORS
# Must include your production frontend URL
CORS_ORIGINS=https://founder-autopilot.com,https://www.founder-autopilot.com
